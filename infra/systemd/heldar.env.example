# /etc/heldar/heldar.env — operator config for the native (systemd) appliance install.
# Copy to /etc/heldar/heldar.env and edit. See .env.example (repo root) for the full variable list.

# ---- Remote-access overlay awareness (optional) ----
# If this box is reached through an externally-run overlay (Tailscale / NetBird / a plain WireGuard
# daemon), point the kernel at the overlay interface so the dashboard can report remote-access health.
# The kernel only OBSERVES the overlay — it does not manage one. Leave disabled for LAN-only.
# HELDAR_OVERLAY_ENABLED=true
# HELDAR_OVERLAY_KIND=tailscale         # tailscale | netbird | wireguard | none
# HELDAR_OVERLAY_IFACE=tailscale0       # the overlay interface to probe (e.g. tailscale0, wt0, wg0)
