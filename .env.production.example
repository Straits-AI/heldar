# Heldar Core — PRODUCTION profile (internet-exposed remote access)
#
# This is the hardened overlay for a deployment reachable from the public internet (via the WebRTC
# rendezvous). Copy the relevant lines into your `.env` ON TOP of `.env.example`. The plain LAN
# appliance does NOT need these — its defaults are intentionally permissive for a trusted network.
# Full rationale + checklist: docs/PRODUCTION.md. Never commit a real `.env` (it holds secrets).

# ---- Authentication (REQUIRED for any networked deployment) ----
# Auth off = every request is a synthetic admin. The kernel REFUSES TO BOOT if a rendezvous is
# configured while this is false.
HELDAR_AUTH_ENABLED=true
# Mark the session cookie Secure (requires HTTPS). The rendezvous terminates TLS, so set this true.
HELDAR_AUTH_COOKIE_SECURE=true
# Bound a stolen session: a shorter absolute lifetime + an idle timeout.
HELDAR_SESSION_TTL_HOURS=4
HELDAR_SESSION_IDLE_TIMEOUT_MIN=30

# ---- Brute-force lockout (per account; complements the rendezvous per-IP rate limit) ----
HELDAR_LOGIN_MAX_FAILURES=5
HELDAR_LOGIN_LOCKOUT_MIN=15

# ---- Encryption at rest for camera credentials ----
# base64 of 32 random bytes, e.g.  openssl rand -base64 32
# Unset = plaintext at rest. When set, existing plaintext passwords are sealed on next boot.
HELDAR_SECRET_KEY=REPLACE_WITH_BASE64_32_BYTES

# ---- CORS ----
# Lock to the dashboard origin (or leave empty for same-origin only). Do NOT ship the localhost default.
HELDAR_CORS_ORIGINS=

# ---- Remote access (the box dials OUT to the rendezvous; no inbound port) ----
HELDAR_REMOTE_RENDEZVOUS_URL=https://your-rendezvous.example.workers.dev
HELDAR_SITE_ID=a-stable-id-for-this-box
HELDAR_CP_TOKEN=SAME_VALUE_AS_THE_WORKER_BOX_TOKEN
# Optional: bring your own STUN/TURN (MediaMTX webrtcICEServers2 JSON); else the rendezvous TURN is used.
# HELDAR_WEBRTC_ICE_SERVERS=

# ---- Strict mode ----
# Turn the production guardrails into hard boot failures (instead of warnings) so a misconfigured
# cookie-Secure / idle-timeout / plaintext-credentials deployment can't start. Recommended for prod.
HELDAR_STRICT_PROD=true

# The Worker (apps/edge) also needs its secrets set — see docs/PRODUCTION.md:
#   wrangler secret put BOX_TOKEN RENDEZVOUS_SECRET RELAY_CAP_SECRET TURN_API_TOKEN [TURNSTILE_SECRET]
# and NEVER set ALLOW_OPEN_BOX_AUTH in production.
