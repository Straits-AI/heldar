# Heldar Core — environment configuration
# Copy to .env and edit. Never commit .env (it holds camera credentials).

# ---- Database ----
# SQLite (WAL) is the only supported store in this release; the URL must start with `sqlite:`.
# (PostgreSQL is not yet supported — the kernel rejects a non-sqlite URL at startup.)
HELDAR_DATABASE_URL=sqlite:///./data/heldar.db
# Max SQLite pool connections (clamped 2..256). Raise for many concurrent cameras/requests; WAL
# serves reads concurrently while writes serialize.
HELDAR_DB_MAX_CONNECTIONS=16

# ---- Storage paths (absolute or relative to repo root) ----
HELDAR_DATA_DIR=./data
HELDAR_RECORDINGS_DIR=./data/recordings
HELDAR_CLIPS_DIR=./data/clips
HELDAR_SNAPSHOTS_DIR=./data/snapshots
# Segment-spanning HLS playback sessions (interactive recorded-footage scrub/seek) are generated here,
# one subdir per session; the cleanup sweeper prunes expired sessions and releases their read-locks.
HELDAR_PLAYBACK_DIR=./data/playback

# ---- Media tooling ----
HELDAR_FFMPEG_BIN=ffmpeg
HELDAR_FFPROBE_BIN=ffprobe

# ---- MediaMTX (live-view gateway) ----
HELDAR_MEDIAMTX_API_URL=http://127.0.0.1:9997
HELDAR_MEDIAMTX_HLS_BASE=http://127.0.0.1:8888
HELDAR_MEDIAMTX_RTSP_BASE=rtsp://127.0.0.1:8554
HELDAR_MEDIAMTX_WEBRTC_BASE=http://127.0.0.1:8889

# ---- Recording policy (conservative defaults — host disk is limited) ----
HELDAR_RECORDER_ENABLED=true
HELDAR_DEFAULT_SEGMENT_SECONDS=60
HELDAR_DEFAULT_RETENTION_HOURS=24
# Default per-camera storage quota (GB) for newly created cameras. 0 = no default quota (NULL).
HELDAR_DEFAULT_CAMERA_QUOTA_GB=0
# Default audio-recording toggle for newly created cameras. false = video only (audio dropped).
HELDAR_DEFAULT_RECORD_AUDIO=false
# Event/motion-triggered recording defaults for newly created cameras (record_mode event /
# scheduled_event). post-roll is the recording window after a trigger (zone event or manual API);
# pre-roll is footage desired before it (best-effort: honored only from recent completed segments —
# there is no always-on ring buffer for idle event cameras). Clamped to pre 0..300, post 0..3600.
HELDAR_DEFAULT_PRE_ROLL_SECONDS=10
HELDAR_DEFAULT_POST_ROLL_SECONDS=30
# How often the schedule watcher opens/closes time-of-day recording windows for `scheduled` cameras
# (seconds). Windows are evaluated against the SERVER's LOCAL timezone (no per-camera timezone).
HELDAR_SCHEDULE_CHECK_INTERVAL_S=30
HELDAR_INDEXER_INTERVAL_S=10
HELDAR_HEALTH_INTERVAL_S=15
HELDAR_RETENTION_INTERVAL_S=300
# Segment-spanning HLS playback sessions. A session read-locks the footage it spans (so retention
# won't prune footage under review) and is auto-removed after this TTL. MAX_PLAYBACK_SECONDS caps a
# single session's requested span (longer is rejected 400). from/to are absolute RFC3339 instants.
HELDAR_PLAYBACK_SESSION_TTL_MINUTES=60
HELDAR_MAX_PLAYBACK_SECONDS=7200

# ---- Storage limits & observability (Stage 1) ----
# Soft cap on total recording footprint; oldest unlocked segments pruned above this.
HELDAR_MAX_RECORDINGS_GB=20
# Hard floor on free disk space; oldest unlocked segments pruned when free space drops below this.
HELDAR_MIN_FREE_DISK_GB=5
# Optional webhook that receives warning/critical events as JSON (alerting). Leave unset to disable.
# HELDAR_ALERT_WEBHOOK_URL=https://hooks.example.com/heldar
HELDAR_NOTIFIER_INTERVAL_S=15
# Prometheus scrapes GET /metrics; liveness GET /healthz; readiness GET /readyz.

# ---- AI frame sampler (Stage 2) — see docs/AI-WORKERS.md ----
# Master switch; false runs no frame samplers (cameras still need an enabled AI task).
HELDAR_AI_ENABLED=true
# Global frame-sampling budget (fps summed across all AI-enabled cameras); per-camera
# fps = min(task fps, budget / active cameras), floored at 0.5. Adding AI cameras
# degrades per-camera fps rather than overloading the host.
HELDAR_AI_MAX_TOTAL_FPS=40
# Defaults for an AI task that omits them (fps clamped 0.1..30, width 160..3840 on write).
HELDAR_DEFAULT_AI_FPS=5
HELDAR_DEFAULT_AI_WIDTH=1280
# Where the latest sampled frame per (camera, stream profile) is written
# (frames/<camera_id>/latest_<profile>.jpg).
HELDAR_FRAMES_DIR=./data/frames
# How long AI detection rows are kept before the retention sweeper prunes them.
HELDAR_DETECTION_RETENTION_HOURS=168

# ---- API ----
HELDAR_API_HOST=0.0.0.0
HELDAR_API_PORT=8000
HELDAR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Embedded dashboard (single-binary serving) ----
# Directory holding the built React dashboard. When set (and the dir exists) the server serves the
# SPA as a fallback so the whole product is ONE binary at ONE URL: /api/*, /media/*, /healthz,
# /readyz and /metrics keep precedence; everything else serves static files, falling back to
# index.html so client-routed deep links work. If unset, it defaults to `apps/web/dist` relative to
# the binary's working directory; when neither exists the server runs API-only (no dashboard).
# Build the dashboard first: cd apps/web && npm run build
# HELDAR_WEB_DIR=./apps/web/dist

# ---- Stage 4: Access control / RBAC ----
# Master switch for authentication + RBAC. Default false = open API (single-tenant LAN appliance):
# the Stage 4 entry/admin surface is reachable without a token and acts as admin. Set true in any
# multi-user / networked deployment to require a bearer token (login session or API key) and enforce
# roles (admin|manager|guard|viewer|integration).
HELDAR_AUTH_ENABLED=false
# Lifetime of an issued login session token (hours).
HELDAR_SESSION_TTL_HOURS=12
# Add `Secure` to the session cookie (HTTPS-only). Keep false for HTTP LAN/overlay; true behind TLS.
HELDAR_AUTH_COOKIE_SECURE=false
# First-run admin bootstrap: when AUTH is enabled and no users exist yet, an admin is seeded from
# these (password must be >= 8 chars). Remove/rotate after first login.
# HELDAR_BOOTSTRAP_ADMIN_USER=admin
# HELDAR_BOOTSTRAP_ADMIN_PASSWORD=change-me-now
# Confidence-weighted plate reads required on a vehicle track before the ANPR engine commits an
# entry event (temporal voting). Higher = more accurate but more latency.
HELDAR_ANPR_MIN_VOTES=3
# API key the AI worker presents (as X-API-Key) when AUTH is enabled. Create one via
# POST /api/v1/api-keys with role "integration", then set it here / in the worker's env. Unused when
# AUTH is disabled. The worker's authenticated surface: GET /ai/tasks, GET /cameras/{id}/frame,
# POST /ai/events.
# HELDAR_API_KEY=vok_...
# How long entry events (+ evidence frames) are kept before the entry app's retention prunes them.
HELDAR_ENTRY_RETENTION_DAYS=365
# How long kernel audit-log + generic event-log rows are kept before the kernel retention prunes them.
HELDAR_AUDIT_RETENTION_DAYS=365

# ---- Stage 6: Movement intelligence (ReID / trails / breach alerts) ----
# How often the ReID candidate proposer + breach rule engine run (seconds).
HELDAR_MOVEMENT_INTERVAL_S=60
# Lookback window each engine tick scans for new events (seconds).
HELDAR_MOVEMENT_SCAN_WINDOW_S=900
# Minimum fused score (0..1) at which a cross-camera candidate is auto-proposed for review.
HELDAR_MOVEMENT_MIN_SCORE=0.5
# Zone `kind` values treated as red/breach zones by the rule engine (comma-separated).
HELDAR_MOVEMENT_RED_ZONE_KINDS=restricted,red
# How long movement candidates + resolved breach alerts are kept before pruning.
HELDAR_MOVEMENT_RETENTION_DAYS=365

# ---- Stage 7: Semantic search ----
# Optional OpenAI-compatible chat endpoint used ONLY to translate a question into a query plan
# (never to produce answers). Unset = the transparent rule-based planner is used (fully offline).
# HELDAR_SEARCH_LLM_URL=https://api.openai.com/v1/chat/completions
# HELDAR_SEARCH_LLM_API_KEY=sk-...
HELDAR_SEARCH_LLM_MODEL=gpt-4o-mini
# Max hits returned per search.
HELDAR_SEARCH_MAX_RESULTS=200

# ---- Remote access (overlay) — see docs/REMOTE-ACCESS.md ----
# A deployment behind CGNAT is reached via a WireGuard overlay running as an EXTERNAL daemon
# (Tailscale for personal/dev, NetBird self-hosted for shipped products). The kernel does NOT manage
# the overlay; it only reports whether the configured interface is up so the dashboard can show
# remote-access health. Leave disabled for LAN-only deployments.
HELDAR_OVERLAY_ENABLED=false
# Label only: tailscale | netbird | wireguard | none
HELDAR_OVERLAY_KIND=none
# Interface the overlay daemon creates, probed for status. Tailscale: tailscale0 ; NetBird: wt0 ;
# plain WireGuard: wg0.
# HELDAR_OVERLAY_IFACE=tailscale0

# ---- Plugin store / registry (Phase C) ----
# Remote signed-catalog URLs (comma-separated). Default EMPTY = no phone-home; the bundled open catalog
# + locally installed plugins always work. Set to the official Straits-AI registry to populate the
# proprietary/community shelves. See website/docs/develop/registry.md.
# HELDAR_REGISTRY_URLS=https://registry.heldar.ai/catalog.json
# HELDAR_REGISTRY_REFRESH_S=900
# HELDAR_REGISTRY_FETCH_TIMEOUT_S=10
# Extra pinned trust anchors for private registries: key_id:base64pubkey,comma-separated.
# HELDAR_REGISTRY_TRUSTED_KEYS=
# HELDAR_REGISTRY_ALLOW_UNVERIFIED=false   # surface unverified remote entries (badged unverified)
# HELDAR_REGISTRY_ALLOW_PRIVATE=false      # allow http / private-IP registry URLs (SSRF guard)

# ---- Sandboxed Wasm plugins (Phase D; requires the server `wasm` cargo feature) ----
# Headless DetectionConsumer plugins loaded from a local dir. Inert unless the feature is built in.
HELDAR_WASM_ENABLED=true
# HELDAR_WASM_PLUGINS_DIR=./data/wasm-plugins
# HELDAR_WASM_FUEL=50000000               # per-call instruction budget (CPU DoS bound)
# HELDAR_WASM_MAX_MEMORY_MB=64            # per-call linear-memory cap
# HELDAR_WASM_MAX_TABLE_ELEMENTS=100000   # per-call table-element cap (tables are host RAM)
# HELDAR_WASM_MAX_EVENTS=64               # events a guest may emit per call
# HELDAR_WASM_MAX_EVENT_BYTES=16384
# HELDAR_WASM_MAX_LOG_CALLS=256
# HELDAR_WASM_MAX_FAILURES=5              # consecutive failures before a plugin is auto-disabled

# ---- Operations / resilience (sane defaults; uncomment to tune) ----
# ANR edge re-fill: refetch missed footage from camera onboard storage to fill recording gaps.
# HELDAR_ANR_ENABLED=false
# HELDAR_ANR_INTERVAL_S=300
# Backup subsystem (scheduled policy jobs; on-demand archive export works regardless).
# HELDAR_BACKUP_ENABLED=false
# HELDAR_RCLONE_BIN=rclone
# Dual/mirror recorder: write a second copy of recordings to this dir (e.g. a NAS mount).
# HELDAR_MIRROR_RECORDINGS_DIR=
# Disk/array health checks in the health loop (needs smartmontools / Linux md).
# HELDAR_SMART_CHECK_ENABLED=false
# HELDAR_SMART_DEVICES=/dev/sda,/dev/sdb
# HELDAR_MDSTAT_CHECK_ENABLED=false
# Live preview transcode engine: software (default) | vaapi | nvenc.
# HELDAR_LIVE_TRANSCODE_ENGINE=software
# Readiness HA probe: require >= this percent of enabled cameras recording for /readyz (0 = off).
# HELDAR_READYZ_MIN_RECORDING_PERCENT=0
# Forensic-search query-log retention (days).
# HELDAR_SEARCH_QUERY_LOG_RETENTION_DAYS=90

# ---- Real HikVision cameras live on 192.168.0.2 .. 192.168.0.12 ----
# RTSP requires credentials. Onboard a camera with POST /api/v1/cameras supplying
# address + username + password; URLs are auto-built from the vendor template.
# Example default credentials placeholders (DO NOT brute force — HikVision locks out):
# CAMERA_DEFAULT_USERNAME=admin
# CAMERA_DEFAULT_PASSWORD=
